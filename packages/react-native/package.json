{
  "name": "@natsuneko-laboratory/fleet-renderer-react-native",
  "version": "0.1.0",
  "description": "React Native renderer and editor helpers for Fleet, built on @natsuneko-laboratory/fleet-renderer-core",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "react-native": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.mjs",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.tsx --format cjs,esm --dts --external react --external react-native",
    "dev": "tsdown src/index.tsx --format cjs,esm --dts --external react --external react-native --watch",
    "test": "echo \"no tests yet\" && exit 0",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "fleet",
    "catalyst",
    "renderer",
    "react-native"
  ],
  "repository": {
    "url": "https://github.com/mika-f/fleet-renderer/"
  },
  "license": "MIT",
  "dependencies": {
    "@natsuneko-laboratory/fleet-renderer-core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.73"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react-native": "^0.86.0",
    "tsdown": "^0.22.7",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}