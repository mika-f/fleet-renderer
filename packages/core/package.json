{
  "name": "@natsuneko-laboratory/fleet-renderer-core",
  "version": "0.1.0",
  "description": "Platform-agnostic types, constants, and layout engine for Fleet rendering",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format cjs,esm --dts",
    "dev": "tsdown src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "fleet",
    "catalyst",
    "renderer",
    "layout"
  ],
  "repository": {
    "url": "https://github.com/mika-f/fleet-renderer/"
  },
  "license": "MIT",
  "devDependencies": {
    "tsdown": "^0.22.7",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
